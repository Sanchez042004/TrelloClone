generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model boards {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(255)
  background String?   @db.VarChar(255)
  user_id    Int?
  guest_id   String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  lists      lists[]
}

model cards {
  id          Int     @id @default(autoincrement())
  title       String  @db.VarChar(255)
  description String?
  position    Int     @default(0)
  list_id     Int?
  image_url   String?
  label       String? @db.VarChar(50)
  priority    String? @db.VarChar(50)
  lists       lists?  @relation(fields: [list_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  card_tags   card_tags[]
}

model lists {
  id       Int     @id @default(autoincrement())
  title    String  @db.VarChar(255)
  position Int     @default(0)
  board_id Int?
  cards    cards[]
  boards   boards? @relation(fields: [board_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id            Int       @id @default(autoincrement())
  username      String?   @unique @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  boards        boards[]
}

model tags {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(50)
  color     String      @db.VarChar(50)
  card_tags card_tags[]
}

model card_tags {
  card_id Int
  tag_id  Int
  cards   cards @relation(fields: [card_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tags    tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([card_id, tag_id])
}
